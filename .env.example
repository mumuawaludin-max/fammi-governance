# ============================================================
# Fammi Governance OS — Environment Variables
# Copy file ini ke .env.local dan isi nilai yang sesuai
# JANGAN commit .env.local ke repository
# ============================================================

# Google Apps Script Web App URL
# Dapatkan dari: Apps Script > Deploy > Manage deployments
APPS_SCRIPT_URL=https://script.google.com/macros/s/[YOUR_SCRIPT_ID]/exec

# Secret key — harus sama dengan nilai di Apps Script Properties (API_SECRET)
# Generate: openssl rand -hex 16
APPS_SCRIPT_SECRET=[RANDOM_32_CHAR_STRING]

# Google OAuth (untuk auth — disetup di Tahap 3)
# Dapatkan dari: console.cloud.google.com > APIs > Credentials
GOOGLE_CLIENT_ID=[FROM_GOOGLE_CLOUD_CONSOLE]
GOOGLE_CLIENT_SECRET=[FROM_GOOGLE_CLOUD_CONSOLE]

# NextAuth
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=[RANDOM_32_CHAR_STRING]
NEXTAUTH_URL=http://localhost:3000

# App Config (public — boleh di-expose ke client)
NEXT_PUBLIC_APP_NAME="Fammi Governance OS"
NEXT_PUBLIC_SCHOOL_TARGET=4000
NEXT_PUBLIC_SCHOOL_CURRENT=55
